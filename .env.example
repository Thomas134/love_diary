# ── 恋爱日记网站 · 环境变量配置 ───────────────────────
# 在 Railway 后台的 Variables 页面填入下面这些变量
# 本地开发时复制此文件为 .env（不要提交 .env 到 git）

# ── 必填 ──────────────────────────────────────────────

# 网站唯一密码（你们共同的专属密码）
SITE_PASSWORD=love2024

# Flask Session 密钥，部署前改成一个随机长字符串
# 可用命令生成：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this

# Railway 会自动注入 DATABASE_URL（PostgreSQL）
# 本地测试时可留空，将使用 SQLite
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Cloudinary（免费图片云存储）─────────────────────
# 注册地址：https://cloudinary.com
# 登录后在 Dashboard 右侧可找到以下三个值
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
